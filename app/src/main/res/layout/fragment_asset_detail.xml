<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="24dp">

            <!-- 1. Location -->
            <TextView style="@style/FieldLabel" android:text="Location" />
            <TextView android:id="@+id/locationValue" style="@style/FieldValue" />

            <!-- 2. ID — with antenna icon -->
            <TextView style="@style/FieldLabel" android:text="ID" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/barcodeValue"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="48dp"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:textSize="15sp"
                    android:textColor="#424242"
                    android:background="@drawable/bg_field_value" />

                <!--
                    Antenna icon — clicking this navigates to LocateTagRFIDFragment.
                    Equivalent to C# TagFinderCommand:
                        var page = new LocateTagRFID(RFIDText, BarcodeText);
                        Navigation.PushAsync(page);
                    android:id added so AssetDetailFragment can attach setOnClickListener.
                -->
                <ImageView
                    android:id="@+id/antennaButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:padding="8dp"
                    android:src="@drawable/antena"
                    android:background="@color/light_blue"
                    android:contentDescription="Find Tag"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- 3. Product SKU -->
            <TextView style="@style/FieldLabel" android:text="Product SKU" />
            <TextView android:id="@+id/productSkuValue" style="@style/FieldValue" />

            <!-- 4. Product Description -->
            <TextView style="@style/FieldLabel" android:text="Product Description" />
            <TextView android:id="@+id/titleValue" style="@style/FieldValue" />

            <!-- 5. Split Number -->
            <TextView style="@style/FieldLabel" android:text="Split Number" />
            <TextView android:id="@+id/splitNumberValue" style="@style/FieldValue" />

            <!-- 6. Pack Description -->
            <TextView style="@style/FieldLabel" android:text="Pack Description" />
            <TextView
                android:id="@+id/packDescriptionValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:gravity="top|start"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:textSize="15sp"
                android:textColor="#424242"
                android:background="@drawable/bg_field_value"
                android:layout_marginBottom="2dp" />

            <!-- 7. M3 CO -->
            <TextView style="@style/FieldLabel" android:text="M3 CO" />
            <TextView android:id="@+id/m3CoValue" style="@style/FieldValue" />

            <!-- 8. Delivery Number -->
            <TextView style="@style/FieldLabel" android:text="Delivery Number" />
            <TextView android:id="@+id/deliveryNumberValue" style="@style/FieldValue" />

            <!-- 9. Customer Name -->
            <TextView style="@style/FieldLabel" android:text="Customer Name" />
            <TextView android:id="@+id/customerNameValue" style="@style/FieldValue" />

            <!-- 10. Shipment Number -->
            <TextView style="@style/FieldLabel" android:text="Shipment Number" />
            <TextView android:id="@+id/shipmentNumberValue" style="@style/FieldValue" />

            <!-- 11. Departure Date -->
            <TextView style="@style/FieldLabel" android:text="Departure Date" />
            <TextView android:id="@+id/departureDateValue" style="@style/FieldValue" />

            <!-- 12. Route -->
            <TextView style="@style/FieldLabel" android:text="Route" />
            <TextView android:id="@+id/routeValue" style="@style/FieldValue" />

            <!-- 13. Address -->
            <TextView style="@style/FieldLabel" android:text="Address" />
            <TextView android:id="@+id/addressValue" style="@style/FieldValue" />

            <!-- 14. Drop Number -->
            <TextView style="@style/FieldLabel" android:text="Drop Number" />
            <TextView android:id="@+id/dropNumberValue" style="@style/FieldValue" />

            <!-- 15. Delivery Instruction -->
            <TextView style="@style/FieldLabel" android:text="Delivery Instruction" />
            <TextView android:id="@+id/deliveryInstructionValue" style="@style/FieldValue" />

            <!-- 16. Supplier Number -->
            <TextView style="@style/FieldLabel" android:text="Supplier Number" />
            <TextView android:id="@+id/supplierNumberValue" style="@style/FieldValue" />

            <!-- 17. Supplier Reference -->
            <TextView style="@style/FieldLabel" android:text="Supplier Reference" />
            <TextView android:id="@+id/supplierReferenceValue" style="@style/FieldValue" />

            <!-- 18. PO Number -->
            <TextView style="@style/FieldLabel" android:text="PO Number" />
            <TextView android:id="@+id/poNumberValue" style="@style/FieldValue" />

            <!-- 19. Girth -->
            <TextView style="@style/FieldLabel" android:text="Girth" />
            <TextView android:id="@+id/girthValue" style="@style/FieldValue" />

            <!-- 20. Number Of Bends -->
            <TextView style="@style/FieldLabel" android:text="Number Of Bends" />
            <TextView android:id="@+id/numberOfBendsValue" style="@style/FieldValue" />

            <!-- 21. Received Date -->
            <TextView style="@style/FieldLabel" android:text="Received Date" />
            <TextView android:id="@+id/receivedDateValue" style="@style/FieldValue" />

            <!-- 22. Weight -->
            <TextView style="@style/FieldLabel" android:text="Weight" />
            <TextView android:id="@+id/weightValue" style="@style/FieldValue" />

            <!-- 23. Length -->
            <TextView style="@style/FieldLabel" android:text="Length" />
            <TextView android:id="@+id/lengthValue" style="@style/FieldValue" />

            <!-- 24. Colour -->
            <TextView style="@style/FieldLabel" android:text="Colour" />
            <TextView android:id="@+id/colourValue" style="@style/FieldValue" />

            <!-- 25. Height -->
            <TextView style="@style/FieldLabel" android:text="Height" />
            <TextView android:id="@+id/heightValue" style="@style/FieldValue" />

            <!-- 26. Width -->
            <TextView style="@style/FieldLabel" android:text="Width" />
            <TextView android:id="@+id/widthValue" style="@style/FieldValue" />

            <!-- 27. Quantity -->
            <TextView style="@style/FieldLabel" android:text="Quantity" />
            <TextView android:id="@+id/quantityValue" style="@style/FieldValue" />

            <!-- 28. Pack Number -->
            <TextView style="@style/FieldLabel" android:text="Pack Number" />
            <TextView android:id="@+id/packNumberValue" style="@style/FieldValue" />

            <!-- 29. Total Pack Number -->
            <TextView style="@style/FieldLabel" android:text="Total Pack Number" />
            <TextView android:id="@+id/totalPackNumberValue" style="@style/FieldValue" />

            <!-- 30. Docket Number -->
            <TextView style="@style/FieldLabel" android:text="Docket Number" />
            <TextView android:id="@+id/docketNumberValue" style="@style/FieldValue" />

            <!-- 31. Customer Reference -->
            <TextView style="@style/FieldLabel" android:text="Customer Reference" />
            <TextView android:id="@+id/customerReferenceValue" style="@style/FieldValue" />

            <!-- 32. M3 DO -->
            <TextView style="@style/FieldLabel" android:text="M3 DO" />
            <TextView android:id="@+id/m3DoValue" style="@style/FieldValue" />

            <!-- 33. Package Structure -->
            <TextView style="@style/FieldLabel" android:text="Package Structure" />
            <TextView android:id="@+id/packageStructureValue" style="@style/FieldValue" />

            <!-- 34. Manufacturing Instruction -->
            <TextView style="@style/FieldLabel" android:text="Manufacturing Instruction" />
            <TextView android:id="@+id/manufacturingInstructionValue" style="@style/FieldValue" />

            <!-- 35. Schedule Number -->
            <TextView style="@style/FieldLabel" android:text="Schedule Number" />
            <TextView android:id="@+id/scheduleNumberValue" style="@style/FieldValue" />

            <!-- 36. Mark Number -->
            <TextView style="@style/FieldLabel" android:text="Mark Number" />
            <TextView android:id="@+id/markNumberValue" style="@style/FieldValue" />

            <!-- 37. Package Number -->
            <TextView style="@style/FieldLabel" android:text="Package Number" />
            <TextView android:id="@+id/packageNumberValue" style="@style/FieldValue" />

            <View android:layout_width="match_parent" android:layout_height="24dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>